# ─── Twilio Credentials ───────────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Twilio WhatsApp sender number (Sandbox: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Your Team WhatsApp Numbers ───────────────────────────────────────────────
# Add up to 4 numbers (comma-separated, with country code, no spaces)
# Example: TEAM_NUMBERS=whatsapp:+917984845750,whatsapp:+919876543210
TEAM_NUMBERS=whatsapp:+91XXXXXXXXXX

# ─── App Settings ─────────────────────────────────────────────────────────────
PORT=3000
COMPANY_NAME=YourCompanyName
